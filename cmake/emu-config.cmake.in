set(EMU_VERSION @PROJECT_VERSION@)

@PACKAGE_INIT@

set(emu_build_cuda @emu_build_cuda@)

include(CMakeFindDependencyMacro)

find_dependency(Boost CONFIG REQUIRED)
find_dependency(fmt CONFIG REQUIRED)
find_dependency(Microsoft.GSL CONFIG REQUIRED)
find_dependency(mdspan CONFIG REQUIRED)
find_dependency(half CONFIG REQUIRED)
find_dependency(tl-expected CONFIG REQUIRED)
find_dependency(tl-optional CONFIG REQUIRED)
find_dependency(dlpack CONFIG REQUIRED)

if(emu_build_cuda)
    find_dependency(CUDAToolkit REQUIRED)
    find_dependency(CCCL CONFIG REQUIRED)
endif()

include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake)

check_required_components(@PROJECT_NAME@)
